---
/**
 * Menu Button Component
 * A clickable button with a hamburger menu icon for navigation
 * 
 * Props:
 * - size: Icon size token (default: 'md' for 24px, can be 'xs' for 16px)
 * - opacity: Custom opacity value (default: 0.7)
 * - ariaLabel: Accessibility label
 * - disabled: Whether the button is disabled
 * - popovertarget: ID of popover element to toggle (for nav menu)
 * 
 * States:
 * - Default: Faded icon (70% opacity or custom)
 * - Hover: Primary purple color (full opacity)
 * - Active: Slightly smaller (scale 0.98) to provide click feedback
 * - Focus: 2px faded border with outline
 * - Disabled: 40% opacity, not clickable
 */

import IconList from '../icons/navigation/IconList.astro';

export interface Props {
  size?: 'xs' | 'sm' | 'md' | 'lg';
  opacity?: number;
  ariaLabel?: string;
  disabled?: boolean;
  /** ID of popover element to toggle (e.g., 'nav') */
  popovertarget?: string;
  /** Checkbox ID for no-JS fallback toggle */
  fallbackCheckboxId?: string;
}

const { 
  size = 'md',
  opacity = 0.7,
  ariaLabel = 'Menu',
  disabled = false,
  popovertarget,
  fallbackCheckboxId = 'nav_toggle_input'
} = Astro.props;

// Map size prop to pixel values
const sizeMap = {
  'xs': '16px',   // 16px (using --icon-sm token value)
  'sm': '20px',   // 20px
  'md': '24px',   // 24px (using --icon-md token value)
  'lg': '32px',   // 32px (using --icon-lg token value)
};

const buttonSize = sizeMap[size];
---

<!-- Button for popover API -->
<button 
  class="button-menu button-menu-popover" 
  type="button"
  aria-label={ariaLabel}
  disabled={disabled}
  popovertarget={popovertarget}
  style={`--button-size: ${buttonSize}; --button-opacity: ${opacity};`}
>
  <span class="icon-wrapper">
    <IconList />
  </span>
</button>

<!-- Label fallback for no-JS (checkbox toggle) -->
<label 
  class="button-menu button-menu-label"
  for={fallbackCheckboxId}
  tabindex="0"
  role="button"
  aria-controls={popovertarget}
  aria-label={ariaLabel}
  style={`--button-size: ${buttonSize}; --button-opacity: ${opacity};`}
>
  <span class="icon-wrapper">
    <IconList />
  </span>
</label>

<style>
  .button-menu {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: var(--button-size);
    height: var(--button-size);
    padding: 0;
    background: transparent;
    border: none;
    border-radius: var(--radius-md);
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .icon-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    color: var(--on-surface-light-regular);
    opacity: var(--button-opacity);
    transition: all 0.2s ease;
  }

  .icon-wrapper :global(svg) {
    width: 100%;
    height: 100%;
  }

  /* Hover state - full opacity, primary purple color */
  .button-menu:hover:not(:focus-visible):not(:disabled) .icon-wrapper {
    color: var(--on-surface-light-primary);
    opacity: 1;
  }

  /* Active state - provides click feedback */
  .button-menu:active:not(:disabled) {
    transform: scale(0.98);
  }

  /* Focus state - 2px faded border with outline */
  .button-menu:focus-visible {
    outline: none;
  }

  .button-menu:focus-visible::after {
    content: '';
    position: absolute;
    inset: 0;
    border: var(--border-lg) solid var(--on-surface-light-faded);
    border-radius: var(--radius-md);
    pointer-events: none;
  }

  /* Disabled state */
  .button-menu:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .button-menu:disabled .icon-wrapper {
    opacity: 0.4;
  }

  /* ========================================
     PROGRESSIVE ENHANCEMENT
     Show label by default (no-JS), hide when popover supported
     ======================================== */
  
  /* Default: show label, hide button */
  .button-menu-popover {
    display: none;
  }
  
  .button-menu-label {
    display: inline-flex;
    cursor: pointer;
  }
  
  /* When popover supported: show button, hide label */
  @supports selector(:popover-open) {
    .button-menu-popover {
      display: inline-flex;
    }
    
    .button-menu-label {
      display: none;
    }
  }
</style>