---
/**
 * Header Component
 * Main navigation header with responsive variants
 * 
 * Variants:
 * - 'mobile': Mobile header with brand, search button, menu button (toggles to close when nav open)
 * - 'mobile-search': Mobile search mode with back button and full-width search bar
 * - 'mobile-search-results': Mobile variant for search results: icon-only brand + search bar
 * - 'desktop': Desktop header with brand and search bar (centered, max-width 968px)
 * - 'desktop-home': Desktop home header with brand and full-width search bar (max-width 1260px)
 * - 'responsive': Auto-switches between mobile (<769px) and desktop (>=769px)
 * - 'responsive-home': Auto-switches between mobile (<769px) and desktop-home (>=769px)
 * - 'responsive-search-results': Auto-switches between mobile-search-results (<769px) and desktop (>=769px)
 */

import ButtonSearch from './ButtonSearch.astro';
import ButtonMenu from './ButtonMenu.astro';
import ButtonClose from './ButtonClose.astro';
import ButtonBack from './ButtonBack.astro';
import InputSearchBar from './InputSearchBar.astro';
import Modal from './Modal.astro';
import IconRocketColorGradient from '../icons/brand/IconRocketColorGradient.astro';

export interface Props {
  variant?: 'mobile' | 'mobile-search' | 'mobile-search-results' | 'desktop' | 'desktop-home' | 'responsive' | 'responsive-home' | 'responsive-search-results';
  homeUrl?: string;
  searchDisabled?: boolean;
  searchButtonDisabled?: boolean;
  /** Show search toggle buttons (popover + checkbox fallback) */
  showSearchToggle?: boolean;
  /** Show search unavailable toggle + dialog */
  showSearchUnavailable?: boolean;
  /** Checkbox ID for no-JS search toggle fallback */
  searchToggleCheckboxId?: string;
  /** Checkbox ID for no-JS search unavailable fallback */
  searchUnavailableCheckboxId?: string;
}

const {
  variant = 'responsive',
  homeUrl = '/',
  searchDisabled = false,
  searchButtonDisabled = false,
  showSearchToggle = false,
  showSearchUnavailable = false,
  searchToggleCheckboxId = 'search_toggle_input',
  searchUnavailableCheckboxId = 'search_unavailable_input',
} = Astro.props;

// For responsive variants, render both mobile and desktop (or mobile-search-results + desktop)
const showMobile = variant === 'mobile' || variant === 'responsive' || variant === 'responsive-home';
const showMobileSearch = variant === 'mobile-search' || variant === 'responsive' || variant === 'responsive-home';
const showMobileSearchResults = variant === 'mobile-search-results' || variant === 'responsive-search-results';
const showDesktop = variant === 'desktop' || variant === 'responsive' || variant === 'responsive-search-results';
const showDesktopHome = variant === 'desktop-home' || variant === 'responsive-home';
---

<header class="header" data-variant={variant}>
  <!-- Border Overlay -->
  <div class="border-overlay" aria-hidden="true"></div>
  
  {showMobile && (
    <!-- Mobile Variant: Brand + Action Buttons (hidden when search active) -->
    <div class="header-content mobile-content">
      <!-- Brand -->
      <a href={homeUrl} class="brand brand-link">
        <div class="brand-icon">
          <IconRocketColorGradient />
        </div>
        <div class="brand-text">
          <span class="brand-text-bold">FF</span>
          <span class="brand-text-regular">Apps Archive</span>
        </div>
      </a>
      
      <!-- Action Buttons -->
      <div class="action-buttons">
        <ButtonSearch disabled={searchButtonDisabled} toggleCheckboxId={searchToggleCheckboxId} />
        <ButtonMenu popovertarget="nav" />
        <ButtonClose popovertarget="nav" popovertargetaction="hide" fallbackCheckboxId="nav_toggle_input" ariaLabel="Close menu" />
      </div>
    </div>
  )}
  
  {showMobileSearchResults && (
    <!-- Mobile Search Results Variant: Icon-only brand + Search Bar + Action Buttons -->
    <div class="header-content mobile-search-results-content">
      <!-- Icon-only Brand -->
      <a href={homeUrl} class="brand brand-link">
        <div class="brand-icon">
          <IconRocketColorGradient />
        </div>
      </a>

      <!-- Search Bar -->
      <div class="search-bar-wrapper">
        <InputSearchBar asForm disabled={searchDisabled} />
      </div>

      <!-- Action Buttons (menu/close) -->
      <div class="action-buttons">
        <ButtonMenu popovertarget="nav" />
        <ButtonClose popovertarget="nav" popovertargetaction="hide" fallbackCheckboxId="nav_toggle_input" ariaLabel="Close menu" />
      </div>
    </div>
  )}
  
  {showMobileSearch && (
    <!-- Mobile Search Variant: Back Button + Search Bar (shown when search active) -->
    <div class="header-content mobile-search-content">
      <ButtonBack toggleCheckboxId={searchToggleCheckboxId} />
      <div class="search-bar-wrapper">
        <InputSearchBar 
          asForm
          disabled={searchDisabled}
        />
      </div>
    </div>
  )}
  
  {showDesktop && (
    <!-- Desktop Variant: Centered with Brand + Search Bar -->
    <div class="header-content-wrapper desktop-wrapper">
      <div class="header-content desktop-content">
        <!-- Brand -->
        <a href={homeUrl} class="brand desktop-brand brand-link">
          <div class="brand-icon">
            <IconRocketColorGradient />
          </div>
          <div class="brand-text desktop-brand-text">
            <span class="brand-text-bold desktop-text-bold">FF</span>
            <span class="brand-text-regular desktop-text-regular">Apps Archive</span>
          </div>
        </a>
        
        <!-- Search Bar -->
        <div class="search-bar-container">
          <InputSearchBar asForm disabled={searchDisabled} />
        </div>
      </div>
    </div>
  )}
  
  {showDesktopHome && (
    <!-- Desktop Home Variant: Brand + Full Search Bar -->
    <div class="header-content desktop-home-content">
      <!-- Brand -->
      <a href={homeUrl} class="brand desktop-brand brand-link">
        <div class="brand-icon">
          <IconRocketColorGradient />
        </div>
        <div class="brand-text desktop-brand-text">
          <span class="brand-text-bold desktop-text-bold">FF</span>
          <span class="brand-text-regular desktop-text-regular">Apps Archive</span>
        </div>
      </a>
      
      <!-- Search Bar -->
      <div class="search-bar-container">
        <InputSearchBar asForm disabled={searchDisabled} />
      </div>
    </div>
  )}
  
  {/* Search Unavailable Modal - shown on hover when search is disabled due to missing WebAssembly */}
  <Modal 
    id="search_unavailable_modal"
    asDialog
    title="Search Unavailable"
    body="Search requires JavaScript and WebAssembly support. Please enable JavaScript and use a modern browser that supports WebAssembly to use search functionality."
    showBadge
  />
</header>

<style>
  /* ========================================
     HEADER BASE
     ======================================== */
  .header {
    position: relative;
    width: 100%;
    min-width: 320px;
    min-height: 64px;
    background: var(--surface-light-low);
    padding: var(--spacing-16);
    overflow: hidden; /* Clip off-screen sliding elements */
    transition: all 0.2s ease;
  }

  /* Border overlay (bottom border) */
  .border-overlay {
    position: absolute;
    inset: 0;
    border-bottom: var(--border-sm) solid var(--on-surface-light-border-low);
    pointer-events: none;
  }

  /* ========================================
     MOBILE VARIANT
     ======================================== */
  .mobile-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    max-width: 968px;
    margin: 0 auto;
  }

  /* Brand Section */
  .brand {
    display: flex;
    align-items: center;
    gap: var(--spacing-8);
  }

  /* Brand Link Styles */
  .brand-link {
    text-decoration: none;
    cursor: pointer;
    border-radius: var(--radius-md);
    transition: all 0.2s ease;
  }

  /* Hover state - overridden by focus */
  .brand-link:hover:not(:focus-visible) {
    opacity: 0.8;
  }

  /* Focus state - takes precedence over hover */
  .brand-link:focus-visible {
    outline: var(--border-lg) solid var(--on-surface-light-faded);
    outline-offset: 2px;
    opacity: 0.8;
  }

  /* Active state - click feedback */
  .brand-link:active {
    transform: scale(0.98);
  }

  .brand-icon {
    width: 32px;
    height: 32px;
    flex-shrink: 0;
  }

  .brand-icon :global(svg) {
    width: 100%;
    height: 100%;
  }

  .brand-text {
    display: flex;
    align-items: flex-end;
    gap: var(--spacing-4);
    color: var(--on-surface-light-regular);
    white-space: nowrap;
    line-height: 0;
  }

  .brand-text-bold {
    font-family: 'Public Sans', sans-serif;
    font-weight: var(--font-weight-bold);
    font-size: var(--brand-bold-sm-size);
    line-height: var(--brand-bold-sm-line);
    letter-spacing: 0;
  }

  .brand-text-regular {
    font-family: 'Public Sans', sans-serif;
    font-weight: var(--font-weight-regular);
    font-size: var(--brand-regular-sm-size);
    line-height: var(--brand-regular-sm-line);
    letter-spacing: 0;
  }

  /* Action Buttons */
  .action-buttons {
    display: flex;
    align-items: center;
    gap: var(--spacing-12);
    height: 32px;
  }
  
  /* Menu/Close button toggle based on nav popover state */
  /* Default: show menu button, hide close button */
  .action-buttons :global(.button-close-popover),
  .action-buttons :global(.button-close-label) {
    display: none;
  }
  
  /* When nav popover is open: hide menu, show close */
  @supports selector(:popover-open) {
    :global(body:has(#nav:popover-open)) .action-buttons :global(.button-menu-popover) {
      display: none;
    }
    
    :global(body:has(#nav:popover-open)) .action-buttons :global(.button-close-popover) {
      display: inline-flex;
    }
  }
  
  /* No-JS fallback: checkbox toggle */
  @supports not selector(:popover-open) {
    :global(body:has(#nav_toggle_input:checked)) .action-buttons :global(.button-menu-label) {
      display: none;
    }
    
    :global(body:has(#nav_toggle_input:checked)) .action-buttons :global(.button-close-label) {
      display: inline-flex;
    }
  }

  /* ========================================
     MOBILE SEARCH RESULTS VARIANT
     Icon-only brand + search bar + actions
     ======================================== */
  .mobile-search-results-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    max-width: 968px;
    margin: 0 auto;
    gap: var(--spacing-12);
  }

  /* Search bar wrapper used in multiple variants */
  .search-bar-wrapper {
    flex: 1 0 0;
    min-width: 0;
  }

  /* ========================================
     MOBILE SEARCH VARIANT
     ======================================== */
  .mobile-search-content {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 100%;
    display: flex;
    align-items: center;
    gap: var(--spacing-12);
    padding: var(--spacing-16);
    background: var(--surface-light-low);
    transform: translateX(100%);
    opacity: 0;
    pointer-events: none;
    transition: transform 0.2s ease-out, opacity 0.2s ease-out;
    z-index: 10;
  }
  
  /* No transition when reset by resize */
  .mobile-search-content.no-transition {
    transition: none !important;
  }
  
  /* When search active (mobile only): show mobile-search sliding from right */
  @media (max-width: 768px) {
    :global(body:has(#search_toggle_input:checked)) .mobile-search-content {
      transform: translateX(0);
      opacity: 1;
      pointer-events: auto;
    }
  }
  
  /* Desktop: always hide mobile-search-content */
  @media (min-width: 769px) {
    .mobile-search-content {
      display: none !important;
    }
  }

  /* ========================================
     DESKTOP VARIANT
     ======================================== */
  .desktop-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
  }

  .desktop-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    max-width: 1260px;
    min-width: 260px;
  }

  .desktop-brand {
    display: flex;
    align-items: center;
    gap: var(--spacing-8);
  }

  .desktop-brand-text {
    display: flex;
    align-items: flex-end;
    gap: var(--spacing-4);
    color: var(--on-surface-light-regular);
    white-space: nowrap;
    line-height: 0;
  }

  .desktop-text-bold {
    font-family: 'Public Sans', sans-serif;
    font-weight: var(--font-weight-bold);
    font-size: var(--brand-bold-md-size);
    line-height: var(--brand-bold-md-line);
    letter-spacing: 0;
  }

  .desktop-text-regular {
    font-family: 'Public Sans', sans-serif;
    font-weight: var(--font-weight-regular);
    font-size: var(--brand-regular-md-size);
    line-height: var(--brand-regular-md-line);
    letter-spacing: 0;
  }

  .search-bar-container {
    width: 287px;
    min-height: 32px;
  }

  /* ========================================
     DESKTOP HOME VARIANT
     ======================================== */
  .desktop-home-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    max-width: 968px;
    margin: 0 auto;
  }

  /* ========================================
     RESPONSIVE VARIANT
     Breakpoint: 769px (--breakpoint-tablet-md)
     ======================================== */
  
  /* When responsive: hide desktop on mobile, hide mobile on desktop */
  .header[data-variant="responsive"] .mobile-content {
    display: flex;
  }
  
  .header[data-variant="responsive"] .desktop-wrapper {
    display: none;
  }
  
  @media (min-width: 769px) {
    .header[data-variant="responsive"] .mobile-content {
      display: none;
    }
    
    .header[data-variant="responsive"] .desktop-wrapper {
      display: flex;
    }
  }

  /* ========================================
     RESPONSIVE-HOME VARIANT
     Switches between mobile and desktop-home
     ======================================== */
  .header[data-variant="responsive-home"] .mobile-content {
    display: flex;
  }
  
  .header[data-variant="responsive-home"] .desktop-home-content {
    display: none;
  }
  
  @media (min-width: 769px) {
    .header[data-variant="responsive-home"] .mobile-content {
      display: none;
    }
    
    .header[data-variant="responsive-home"] .desktop-home-content {
      display: flex;
    }
  }

  /* ========================================
     RESPONSIVE-SEARCH-RESULTS VARIANT
     Switches between mobile-search-results and desktop
     ======================================== */
  .header[data-variant="responsive-search-results"] .mobile-search-results-content {
    display: flex;
  }
  
  .header[data-variant="responsive-search-results"] .desktop-wrapper {
    display: none;
  }
  
  @media (min-width: 769px) {
    .header[data-variant="responsive-search-results"] .mobile-search-results-content {
      display: none;
    }
    
    .header[data-variant="responsive-search-results"] .desktop-wrapper {
      display: flex;
    }
  }
</style>
