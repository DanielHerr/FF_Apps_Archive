---
/**
 * App Details Page - FF Apps Archive
 * Dynamic app detail page using the new UI component system
 */
import * as Content from "astro:content"

// Import layout
import Base from "../../layouts/base.astro"

// Import UI components
import SectionHeadline from "../../components/UI/SectionHeadline.astro"
import SectionAppDetail from "../../components/UI/SectionAppDetail.astro"
import SectionScreenGallery from "../../components/UI/SectionScreenGallery.astro"
import SectionAppDescription from "../../components/UI/SectionAppDescription.astro"
import SectionVersion from "../../components/UI/SectionVersion.astro"
import SectionSupport from "../../components/UI/SectionSupport.astro"
import SectionReleaseNotes from "../../components/UI/SectionReleaseNotes.astro"
import Button from "../../components/UI/Button.astro"
import Link from "../../components/UI/Link.astro"
import MenuAppCategories from "../../components/UI/MenuAppCategories.astro"
import LabelWarning from "../../components/UI/LabelWarning.astro"

// Import data sources
import categories from "../../categories.json" with { type: "json" }
import { pwa_data } from "../../validate_hosted_apps.js"

export async function getStaticPaths() {
	let apps = await Content.getCollection("metadata")
	return apps.map(app => ({
		params: { slug: app.data.slug }, props: { app },
	}))
}

// Get app data from props
let { app } = Astro.props
let pwa = pwa_data ? pwa_data[app.data.slug] : undefined

// Extract localized strings
let name = app.data.name["en-US"] ?? app.data.name.en ?? app.data.name[app.data.default_locale]
let manifest = app.data.app_type == "hosted" ? app.data.manifest_url : app.data.manifest_url.split("/").pop()
let description = app.data.description ? app.data.description["en-US"] ?? app.data.description.en ?? app.data.description[app.data.default_locale] : ""
let homepage = app.data.homepage ? app.data.homepage["en-US"] ?? app.data.homepage.en ?? app.data.homepage[app.data.default_locale] : null
let supportemail = app.data.support_email ? app.data.support_email["en-US"] ?? app.data.support_email.en ?? app.data.support_email[app.data.default_locale] : null
let supporturl = app.data.support_url ? app.data.support_url["en-US"] ?? app.data.support_url.en ?? app.data.support_url[app.data.default_locale] : null
let releasenotes = app.data.release_notes ? app.data.release_notes["en-US"] ?? app.data.release_notes.en ?? app.data.release_notes[app.data.default_locale] : null

// Map app_type to UI component appType
const appTypeMap: Record<string, 'Packaged' | 'Privileged' | 'Live' | 'Dead'> = {
	'hosted': 'Live',
	'packaged': 'Packaged',
	'privileged': 'Privileged',
	'dead': 'Dead'
}
let appType = appTypeMap[app.data.app_type] || 'Live'

// Build screenshot URLs
let screenshots = app.data.previews.map(preview => "screenshots/" + preview.id + ".png")

// Map category slugs to objects with name and href
let categoryData = app.data.categories.map(slug => {
	const cat = categories.find(c => c.slug == slug)
	return {
		name: cat ? cat.name : slug,
		href: `/${slug}/A`
	}
}).slice(0, 2) // MenuAppCategories only supports 1-2 categories

// Format file size
let appSize = app.data.app_type != "hosted" && app.data.file_size 
	? Math.round(app.data.file_size / 1024 / 1024) + " MB" 
	: "N/A"

// Generate publisher page URL from author name
let publisherSlug = app.data.author
	? app.data.author.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '')
	: null
let publisherUrl = publisherSlug ? `/publisher/${publisherSlug}` : "#"

// Format date to: "2026, March 10 - 18:42h TZ"
function formatDate(dateStr: string): string {
	if (!dateStr) return "N/A"
	const date = new Date(dateStr)
	if (isNaN(date.getTime())) return "N/A"
	
	const year = date.getFullYear()
	const month = date.toLocaleString('en-US', { month: 'long' })
	const day = date.getDate()
	const hours = date.getHours().toString().padStart(2, '0')
	const minutes = date.getMinutes().toString().padStart(2, '0')
	
	// Get timezone abbreviation
	const tz = date.toLocaleTimeString('en-US', { timeZoneName: 'short' }).split(' ').pop() || 'UTC'
	
	return `${year}, ${month} ${day} - ${hours}:${minutes}h ${tz}`
}

let formattedUpdateDate = formatDate(app.data.last_updated)
let formattedCreatedDate = formatDate(app.data.created)
---

<Base title={name} searchable>
	<Fragment slot="imports">
		<link rel="stylesheet" href="/details.css">
		{ app.data.app_type != "privileged" && <script src="/install.js" defer nomodule></script> }
		{ app.data.app_type == "hosted" && pwa && <script src="/install.mjs" type="module"></script> }
	</Fragment>
	<link slot="icon" rel="icon" href={ "/app/" + app.data.slug + "/" + app.data.id + "-128.png" } type="image/png" data-pagefind-meta="image[href]">

	<!-- Empty header slot - headline is inside app-detail-wrapper -->
	<Fragment slot="header"></Fragment>

	<!-- Main content -->
	<div class="app-details-container">
		<!-- App Details Header Section with overlaid headline -->
		<div class="section-wrapper app-detail-wrapper">
			<div class="headline-overlay">
				<SectionHeadline 
					variant="sub-only" 
					subHeaderText="App Details"
					pagefindMeta="title"
				/>
			</div>
			<SectionAppDetail
				appName={name}
				appIconSrc={app.data.id + "-128.png"}
				starRating={String(app.data.ratings.average)}
				userCount={String(app.data.ratings.count)}
				appType={appType}
				publisherName={app.data.author}
				publisherUrl={publisherUrl}
			/>
			
			<!-- Action Buttons Section -->
			<div class="action-buttons">
				{ app.data.app_type == "hosted" && 
					<Button 
						id="install_button"
						label="Install"
						variant="primary"
						disabled
						data-manifest={manifest}
						data-pwa-page={pwa && pwa.install_page}
						data-pwa-id={pwa && pwa.id}
						data-pwa-manifest={pwa && pwa.manifest_url}
					/>
				}
				{ app.data.app_type == "packaged" && 
					<Button 
						id="install_button"
						label="Install"
						variant="primary"
						disabled
						data-manifest={manifest}
					/>
				}
				{ app.data.package_path && 
					<Button
						label="Download"
						variant="secondary"
						href={app.data.package_path.split("/").pop()}
						download
					/>
				}
				
				<!-- Sideloading Instructions Link (for privileged apps) -->
				{ app.data.app_type == "privileged" && 
					<div class="sideloading-link">
						<Link 
							href="/sideloading" 
							label="Sideloading Instructions"
						/>
					</div>
				}
			</div>
		</div>

		<!-- Screenshot Gallery Section -->
		{ screenshots.length > 0 && 
			<div class="section-wrapper gallery-wrapper">
				<!-- Mobile gallery -->
				<div class="gallery-mobile">
					<SectionScreenGallery 
						variant="mobile"
						images={screenshots}
					/>
				</div>
				<!-- Desktop gallery -->
				<div class="gallery-desktop">
					<SectionScreenGallery 
						variant="desktop"
						images={screenshots}
					/>
				</div>
			</div>
		}

		<!-- Category Tags and Warning Label Row -->
		<div class="categories-warning-row">
			<!-- Category Tags Section -->
			<div class="section-wrapper categories-wrapper">
				<MenuAppCategories 
					categories={categoryData}
				/>
				<!-- Hidden elements for pagefind filtering -->
				{ app.data.categories.map(slug => 
					<span class="visually-hidden" data-pagefind-filter="category">
						{categories.find(c => c.slug == slug)?.name}
					</span>
				)}
			</div>

			<!-- Warning Label (desktop only) -->
			{ !app.data.is_offline && 
				<div class="warning-desktop">
					<LabelWarning 
						text="This app does not support offline use"
					/>
				</div>
			}
		</div>

		<!-- Description Section -->
		{ description && 
			<div class="section-wrapper description-wrapper">
				<SectionAppDescription 
					description={description}
				/>
			</div>
		}

		<!-- Warning Label (mobile only) -->
		{ !app.data.is_offline && 
			<div class="warning-mobile">
				<LabelWarning 
					text="This app does not support offline use"
				/>
			</div>
		}

		<!-- Version, Support, Release Notes Grid -->
		<div class="info-grid">
			<!-- Release Notes Section -->
			{ releasenotes && 
				<div class="section-wrapper release-notes-wrapper">
					<SectionReleaseNotes 
						releaseNotes={releasenotes}
					/>
				</div>
			}

			<!-- Version Section -->
			<div class="section-wrapper version-wrapper">
				<SectionVersion 
					version={app.data.current_version}
					appSize={appSize}
					updateDate={formattedUpdateDate}
					createdDate={formattedCreatedDate}
				/>
			</div>

			<!-- Support Section -->
			{ (supportemail || homepage) && 
				<div class="section-wrapper support-wrapper">
					<SectionSupport 
						emailLink={supportemail ? "mailto:" + supportemail : ""}
						websiteLink={homepage || ""}
					/>
				</div>
			}
		</div>

		<!-- Hidden App Type for pagefind filtering -->
		<span class="visually-hidden" data-pagefind-filter="type">{app.data.app_type}</span>
	</div>
</Base>

<style>
	/* ========================================
	   OVERRIDE BASE LAYOUT
	   Fix extra scroll space below footer
	   ======================================== */
	:global(html) {
		overflow: hidden;
	}

	/* ========================================
	   APP DETAILS CONTAINER
	   ======================================== */
	
	.app-details-container {
		display: flex;
		flex-direction: column;
		width: 100%;
		max-width: 1000px;
		margin: 0 auto;
		background: var(--surface-light-mid);
	}

	.app-detail-wrapper {
		position: relative;
		padding: 0;
		height: fit-content;
		width: 100%;
	}

	.headline-overlay {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		z-index: 10;
	}

	/* Override SectionHeadline sub-header typography for this page */
	.headline-overlay :global(.sub-header) {
		font-size: var(--body-xxs-size);
		line-height: var(--body-xxs-line);
	}
	.headline-overlay :global(.section-headline) {
		padding-left: var(--spacing-4);
	}

	/* Override SectionAppDetail padding */
	.app-detail-wrapper :global(.section-app-detail) {
		padding: var(--spacing-20) 0;
	}
	
	.action-buttons {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-8);
		padding: var(--spacing-12) 0;
		width: 100%;
	}

	.sideloading-link {
		display: flex;
		align-items: center;
		justify-content: center;
		padding: var(--spacing-12) var(--spacing-4);
	}

	/* Override Link component typography for sideloading link */
	.sideloading-link :global(.link) {
		font-family: var(--font-inter);
		font-weight: var(--font-weight-regular);
		font-size: var(--body-sm-size);
		line-height: var(--body-sm-line);
		color: var(--link-primary);
	}

	/* Mobile: Show mobile gallery, hide desktop */
	.gallery-mobile {
		display: block;
		width: 100%;
		height: 200px;
	}

	.gallery-desktop {
		display: none;
		width: 100%;
		height: 400px;
	}

	/* Warning label visibility */
	.warning-mobile {
		display: block;
	}

	.warning-desktop {
		display: none;
	}

	/* ========================================
	   UTILITY CLASSES
	   ======================================== */

	.visually-hidden {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}

	/* ========================================
	   RESPONSIVE: DESKTOP (769px and above)
	   ======================================== */
	
	@media (min-width: 769px) {
		.app-details-container {
			max-width: 1000px;
		}

		/* Override H2 typography on desktop */
		.app-details-container :global(h2) {
			font-size: var(--heading-xxs-size);
			line-height: var(--heading-xxs-line);
		}

		/* Override SectionAppDetail padding */
		.app-detail-wrapper :global(.section-app-detail) {
			padding: var(--spacing-48) 0;
		}

		/* Action Buttons - Absolutely positioned on desktop */
		.action-buttons {
			position: absolute;
			bottom: var(--spacing-16);
			right: var(--spacing-16);
			flex-direction: column;
			gap: var(--spacing-8);
			width: 168px;
			padding: 0;
			align-items: center;
			z-index: 15;
		}

		/* Make buttons equal width on desktop */
		.action-buttons :global(.button) {
			flex: 1;
			max-width: 200px;
		}

		.sideloading-link {
			flex: 0 0 auto;
			padding: var(--spacing-4);
        	padding-bottom: 0;
		}

		/* Desktop: Hide mobile gallery, show desktop */
		.gallery-mobile {
			display: none;
		}

		.gallery-desktop {
			display: block;
			width: 100%;
			height: 400px;
		}

		/* Info Grid - 2 row layout on desktop */
		.info-grid {
			display: flex;
			flex-wrap: wrap;
			column-gap: var(--spacing-24);
		}

		.info-grid .release-notes-wrapper {
			order: 1;
			width: 100%;
		}

		.info-grid .version-wrapper {
			order: 2;
		}

		.info-grid .support-wrapper {
			order: 3;
		}

		/* Categories and Warning side by side on desktop */
		.categories-warning-row {
			display: flex;
			justify-content: space-between;
			align-items: center;
		}

		/* Warning label visibility on desktop */
		.warning-mobile {
			display: none;
		}

		.warning-desktop {
			display: block;
		}
	}
</style>